<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="other_consumers_subreport"
              pageWidth="555"
              pageHeight="842"
              columnWidth="555"
              leftMargin="0"
              rightMargin="0"
              topMargin="0"
              bottomMargin="0">

    <!-- Parameter for tariffs detail subreport -->
    <parameter name="TARIFFS_DETAIL_SUBREPORT" class="net.sf.jasperreports.engine.JasperReport"/>

    <!-- Fields from SubGroupSection DTO -->
    <field name="subGroupName" class="java.lang.String"/>
    <field name="tariffs" class="java.util.List"/>

    <!-- Group by Sub-Group Name -->
    <group name="subGroupGroup">
        <groupExpression><![CDATA[$F{subGroupName}]]></groupExpression>
        <groupHeader>
            <band height="25" splitType="Stretch">
                <!-- Sub-Group Header Background -->
                <rectangle>
                    <reportElement x="0" y="0" width="555" height="25" backcolor="#DDDDDD"/>
                    <graphicElement>
                        <pen lineWidth="0.5" lineColor="#999999"/>
                    </graphicElement>
                </rectangle>

                <!-- Sub-Group Name -->
                <textField>
                    <reportElement x="5" y="4" width="545" height="18"/>
                    <textElement verticalAlignment="Middle">
                        <font fontName="Times New Roman" size="10" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{subGroupName}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
    </group>

    <!-- Column Header Band -->
    <columnHeader>
        <band height="25" splitType="Stretch">
            <!-- Header Background -->
            <rectangle>
                <reportElement x="0" y="0" width="555" height="25" backcolor="#7C0000"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>

            <!-- Column 1: Threshold -->
            <staticText>
                <reportElement x="5" y="5" width="240" height="20" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="Times New Roman" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Threshold]]></text>
            </staticText>

            <!-- Column 2: Energy Rate -->
            <staticText>
                <reportElement x="250" y="5" width="140" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Times New Roman" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Energy Rate (Rs/kWh)]]></text>
            </staticText>

            <!-- Column 3: Fixed Charge -->
            <staticText>
                <reportElement x="395" y="5" width="150" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Times New Roman" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Fixed Charge (Rs)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Detail Band - Calls tariffs detail subreport -->
    <detail>
        <band height="20" splitType="Stretch">
            <subreport>
                <reportElement x="0" y="0" width="555" height="20"/>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($F{tariffs})]]></dataSourceExpression>
                <subreportExpression><![CDATA[$P{TARIFFS_DETAIL_SUBREPORT}]]></subreportExpression>
            </subreport>
        </band>
    </detail>

</jasperReport>
