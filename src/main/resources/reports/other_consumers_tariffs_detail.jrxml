<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="other_consumers_tariffs_detail"
              pageWidth="555"
              pageHeight="842"
              columnWidth="555"
              leftMargin="0"
              rightMargin="0"
              topMargin="0"
              bottomMargin="0">

    <!-- Fields from SimpleTariffDisplay DTO -->
    <field name="thresholdLabel" class="java.lang.String"/>
    <field name="energyRate" class="java.lang.String"/>
    <field name="fixedCharge" class="java.lang.String"/>

    <!-- Detail Band - Table Rows -->
    <detail>
        <band height="20" splitType="Stretch">
            <!-- Row Background -->
            <rectangle>
                <reportElement x="0" y="0" width="555" height="20" backcolor="#F5F5F5"/>
                <graphicElement>
                    <pen lineWidth="0.25" lineColor="#CCCCCC"/>
                </graphicElement>
            </rectangle>

            <!-- Threshold Column -->
            <textField>
                <reportElement x="5" y="2" width="240" height="16"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="Times New Roman" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{thresholdLabel}]]></textFieldExpression>
            </textField>

            <!-- Energy Rate Column -->
            <textField>
                <reportElement x="250" y="2" width="140" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Times New Roman" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{energyRate}]]></textFieldExpression>
            </textField>

            <!-- Fixed Charge Column -->
            <textField>
                <reportElement x="395" y="2" width="150" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Times New Roman" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{fixedCharge}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>
