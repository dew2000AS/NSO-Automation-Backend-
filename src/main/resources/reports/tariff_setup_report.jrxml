<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="tariff_setup_report"
              pageWidth="595"
              pageHeight="842"
              columnWidth="535"
              leftMargin="30"
              rightMargin="30"
              topMargin="30"
              bottomMargin="30">

	<parameter name="REPORT_DATE" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String"/>
	<parameter name="SUBREPORT" class="net.sf.jasperreports.engine.JasperReport"/>

	<field name="tariffId" class="java.lang.Short"/>
	<field name="tariffName" class="java.lang.String"/>
	<field name="fromDate" class="java.util.Date"/>
	<field name="toDate" class="java.util.Date"/>
	<field name="numberOfSlabs" class="java.lang.Short"/>
	<field name="minCharge" class="java.math.BigDecimal"/>
	<field name="blocks" class="java.util.List"/>

	<title>
		<band height="80" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="10" width="535" height="30"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Times New Roman" size="20" isBold="true"/>
				</textElement>
				<text><![CDATA[Tariff Setup Report - Active Tariffs]]></text>
			</staticText>
			<textField>
				<reportElement x="0" y="45" width="535" height="20"/>
				<textElement textAlignment="Center">
					<font fontName="Times New Roman" size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["Generated: " + $P{REPORT_DATE}]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="0" y="75" width="535" height="1"/>
			</line>
		</band>
	</title>

	<pageHeader>
		<band height="5" splitType="Stretch"/>
	</pageHeader>

	<columnHeader>
		<band height="30" splitType="Stretch">
			<rectangle>
				<reportElement x="0" y="0" width="535" height="25" backcolor="#7C0000"/>
				<graphicElement>
					<pen lineWidth="0.5"/>
				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="5" y="5" width="200" height="20" forecolor="#FFFFFF"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Times New Roman" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[Tariff Name]]></text>
			</staticText>
			<staticText>
				<reportElement x="210" y="5" width="50" height="20" forecolor="#FFFFFF"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Times New Roman" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[ID]]></text>
			</staticText>
			<staticText>
				<reportElement x="265" y="5" width="80" height="20" forecolor="#FFFFFF"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Times New Roman" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[From Date]]></text>
			</staticText>
			<staticText>
				<reportElement x="350" y="5" width="80" height="20" forecolor="#FFFFFF"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Times New Roman" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[To Date]]></text>
			</staticText>
			<staticText>
				<reportElement x="435" y="5" width="95" height="20" forecolor="#FFFFFF"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Times New Roman" size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[No. of Slabs]]></text>
			</staticText>
		</band>
	</columnHeader>

	<detail>
		<band height="150" splitType="Stretch">
			<!-- Tariff Basic Info Row -->
			<rectangle>
				<reportElement x="0" y="0" width="535" height="25" backcolor="#F5F5F5"/>
				<graphicElement>
					<pen lineWidth="0.5" lineColor="#CCCCCC"/>
				</graphicElement>
			</rectangle>
			<textField isBlankWhenNull="true">
				<reportElement x="5" y="5" width="200" height="15"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{tariffName}]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="210" y="5" width="50" height="15"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{tariffId}]]></textFieldExpression>
			</textField>
			<textField pattern="dd/MM/yyyy" isBlankWhenNull="true">
				<reportElement x="265" y="5" width="80" height="15"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{fromDate}]]></textFieldExpression>
			</textField>
			<textField pattern="dd/MM/yyyy" isBlankWhenNull="true">
				<reportElement x="350" y="5" width="80" height="15"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{toDate} != null ? $F{toDate} : "-"]]></textFieldExpression>
			</textField>
			<textField isBlankWhenNull="true">
				<reportElement x="435" y="5" width="95" height="15"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{numberOfSlabs}]]></textFieldExpression>
			</textField>

			<!-- Subreport for Tariff Blocks -->
			<subreport>
				<reportElement x="10" y="30" width="515" height="115" isPrintWhenDetailOverflows="true"/>
				<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($F{blocks})]]></dataSourceExpression>
				<subreportExpression><![CDATA[$P{SUBREPORT}]]></subreportExpression>
			</subreport>
		</band>
	</detail>

	<columnFooter>
		<band height="5" splitType="Stretch"/>
	</columnFooter>

	<pageFooter>
		<band height="30" splitType="Stretch">
			<line>
				<reportElement x="0" y="5" width="535" height="1"/>
			</line>
			<textField>
				<reportElement x="0" y="10" width="260" height="15"/>
				<textElement>
					<font fontName="Times New Roman" size="9"/>
				</textElement>
				<textFieldExpression><![CDATA["Ceylon Electricity Board - Tariff Setup"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="435" y="10" width="55" height="15"/>
				<textElement textAlignment="Right">
					<font fontName="Times New Roman" size="9"/>
				</textElement>
				<textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
			</textField>
			<textField evaluationTime="Report">
				<reportElement x="490" y="10" width="45" height="15"/>
				<textElement textAlignment="Left">
					<font fontName="Times New Roman" size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[" of " + $V{PAGE_NUMBER}]]></textFieldExpression>
			</textField>
		</band>
	</pageFooter>

	<summary>
		<band height="5" splitType="Stretch"/>
	</summary>
</jasperReport>
